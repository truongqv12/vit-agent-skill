{
  "Button/Primary": {
    "component": "Button",
    "import": "@/components/ui/Button",
    "match": {
      "role": "button-bg",
      "css.backgroundColor": "#2563eb"
    },
    "props": {
      "variant": "primary"
    }
  },
  "Button/Secondary": {
    "component": "Button",
    "import": "@/components/ui/Button",
    "match": {
      "role": "button-bg",
      "css.backgroundColor": "#ffffff"
    },
    "props": {
      "variant": "secondary"
    }
  },
  "Input/Text": {
    "component": "Input",
    "import": "@/components/ui/Input",
    "match": {
      "element": "input"
    }
  },
  "Select/Default": {
    "component": "Select",
    "import": "@/components/ui/Select",
    "match": {
      "element": "select-or-date-control"
    }
  }
}
